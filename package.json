{
  "name": "marcaflow",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:generate": "pnpm --filter @marcaflow/database generate",
    "db:push": "pnpm --filter @marcaflow/database push",
    "db:seed": "pnpm --filter @marcaflow/database seed",
    "db:studio": "pnpm --filter @marcaflow/database studio",
    "setup": "pnpm install && pnpm db:up && sleep 3 && pnpm db:generate && pnpm db:push && pnpm db:seed"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.4.0"
}
